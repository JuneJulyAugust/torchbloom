    "text": "\\begin{aligned}\\mathbf{H}_{1}&=\\quad\\mathbf{a}\\left[\\boldsymbol{\\beta}_{0}\\mathbf{1}^{T}+\\boldsymbol{\\Omega}_{0}\\mathbf{X}(\\mathbf{A}+\\mathbf{I})\\right]\\\\ \\mathbf{H}_{2}&=\\quad\\mathbf{a}\\left[\\boldsymbol{\\beta}_{1}\\mathbf{1}^{T}+\\boldsymbol{\\Omega}_{1}\\mathbf{H}_{1}(\\mathbf{A}+\\mathbf{I})\\right]\\\\\\vdots&=\\quad\\vdots\\\\ \\mathbf{H}_{K}&=\\quad\\mathbf{a}\\left[\\boldsymbol{\\beta}_{\\mathcal{K}-1}\\mathbf{1}^{T}+\\boldsymbol{\\Omega}_{K-1}\\mathbf{H}_{\\mathcal{K}-1}(\\mathbf{A}+\\mathbf{I})\\right]\\\\ \\mathbf{f}[\\mathbf{X},\\mathbf{A},\\boldsymbol{\\Phi}]&=\\quad\\mathrm{sig}\\left[\\beta_{K}+\\omega_{K}\\mathbf{H}_{K}\\mathbf{1}/N\\right],\\end{aligned} \\quad (13.11)"
